---
import Base from "@layouts/Base.astro";
import { pageTitle } from "@lib/site";
import { withBase } from "@lib/paths";
import { TREE, START_NODE_ID, TOTAL_MAJOR_STEPS } from "@lib/tree";

// Serialize tree into a JSON island for the client controller.
const treeConfig = {
  tree: TREE,
  startId: START_NODE_ID,
  totalSteps: TOTAL_MAJOR_STEPS,
};

const referenceHref = withBase("/reference");
const title = pageTitle("Assessment");
const description =
  "Step-by-step Microsoft 365 licensing decision tree. Card-based questionnaire with source citations and downloadable PDF handout.";
---

<Base title={title} description={description} pageClass="page-assessment" ogImageSlug="assessment">
  <section class="assessment-intro">
    <div class="container">
      <p class="eyebrow">Interactive assessment</p>
      <h1>Find the right Microsoft 365 license</h1>
      <p class="lede">
        Answer a few short questions about the tenant baseline, identity profile, and feature
        requirements. Every screen cites Microsoft Learn and other primary sources so you can verify
        each step. Your answers stay on this device — no accounts, no tracking.
      </p>
    </div>
  </section>

  <section class="assessment-shell">
    <div class="container">
      <div id="assessment" aria-live="polite" aria-busy="false">
        <noscript>
          <div class="callout callout--warn">
            <strong>JavaScript is required for the interactive assessment.</strong>
            Browse the <a href={referenceHref}>Reference catalog</a>
            instead to read every recommendation as a static page.
          </div>
        </noscript>
      </div>
    </div>
  </section>

  <!-- SSR-rendered tree data — consumed by the client controller. -->
  <script is:inline id="tree-data" type="application/json" set:html={JSON.stringify(treeConfig)} />

  <script>
    import "@client/assessment.ts";
  </script>
</Base>

<style is:global>
  .page-assessment .assessment-intro {
    background: var(--color-bg-tint);
    padding: 2.5rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .page-assessment .eyebrow {
    text-transform: uppercase;
    color: var(--ms-blue);
    font-weight: 700;
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    margin: 0 0 0.25rem;
  }
  .page-assessment h1 {
    margin: 0 0 0.5rem;
    font-size: var(--fs-2xl);
  }
  .page-assessment .lede {
    max-width: 720px;
    color: var(--color-text-soft);
    margin: 0;
  }
  .assessment-shell {
    padding: 2rem 0 4rem;
  }

  /* ---------- Assessment card internals ---------- */
  .assess__controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .question-card {
    max-width: 900px;
    margin: 0 auto;
  }
  .question-card__q {
    font-size: var(--fs-xl);
    line-height: 1.35;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }
  .question-card__help {
    color: var(--color-text-soft);
    margin: 0 0 1.25rem;
    font-size: var(--fs-md);
    line-height: 1.55;
  }

  .rationale {
    background: var(--color-bg-tint);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin: 1rem 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.4rem 1rem;
    font-size: var(--fs-sm);
  }
  .rationale dt {
    font-weight: 600;
    color: var(--color-text);
  }
  .rationale dd {
    margin: 0;
    color: var(--color-text-soft);
  }

  .examples {
    margin: 1rem 0;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
    padding: 0.5rem 1rem;
    background: var(--color-bg-alt);
  }
  .examples summary {
    cursor: pointer;
    font-weight: 600;
    padding: 0.25rem 0;
    color: var(--color-text-soft);
  }
  .examples ul {
    margin: 0.5rem 0 0.5rem 1.25rem;
    padding: 0;
  }
  .examples li {
    margin-bottom: 0.35rem;
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
  }

  .yesno {
    display: flex;
    gap: 0.75rem;
    margin: 1.5rem 0 0.5rem;
    flex-wrap: wrap;
  }
  .yesno .btn {
    min-width: 110px;
    padding: 0.75em 1.5em;
    font-size: var(--fs-base);
  }

  .choices {
    display: grid;
    gap: 0.75rem;
    margin: 1.5rem 0 0.5rem;
  }
  .choice {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    text-align: left;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.9rem 1.1rem;
    cursor: pointer;
    font: inherit;
    color: var(--color-text);
    transition:
      border-color 0.15s,
      background 0.15s,
      transform 0.05s;
  }
  .choice:hover {
    border-color: var(--ms-blue);
    background: var(--ms-blue-lighter);
    text-decoration: none;
  }
  .choice:active {
    transform: translateY(1px);
  }
  :root[data-theme="dark"] .choice {
    background: var(--color-bg-alt);
  }
  :root[data-theme="dark"] .choice:hover {
    background: #25364b;
    border-color: #3ea6ff;
  }
  .choice--warning {
    border-left: 4px solid var(--color-warning);
  }
  .choice--ghost {
    border-style: dashed;
    color: var(--color-text-soft);
  }
  .choice__icon {
    flex: 0 0 auto;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    background: var(--ms-blue);
    color: #fff;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--fs-sm);
  }
  .choice--warning .choice__icon {
    background: var(--color-warning);
  }
  .choice--ghost .choice__icon {
    background: var(--color-border-strong);
    color: var(--color-text);
  }
  .choice__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .choice__label {
    font-weight: 600;
  }
  .choice__sub {
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
    line-height: 1.5;
  }

  .info-card .card__title,
  .result-card .card__title {
    font-size: var(--fs-2xl);
  }
  .result-card {
    max-width: 920px;
    margin: 0 auto;
  }
  .result-card__bullets {
    padding-left: 1.25rem;
    margin: 1rem 0;
  }
  .result-card__bullets li {
    margin-bottom: 0.4rem;
  }
  .result-card__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 1rem;
  }

  .trail {
    max-width: 900px;
    margin: 1.5rem auto 0;
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
  }
  .trail details {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.5rem 1rem;
  }
  .trail summary {
    cursor: pointer;
    font-weight: 600;
  }
  .trail__list {
    margin: 0.75rem 0 0;
    padding-left: 1.5rem;
  }
  .trail__list li {
    margin-bottom: 0.5rem;
  }
  .trail__q {
    display: block;
    color: var(--color-text);
  }
  .trail__a {
    display: block;
    color: var(--ms-blue);
    font-weight: 600;
  }

  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius);
    font-size: var(--fs-sm);
    box-shadow: var(--shadow-modal);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s,
      transform 0.2s;
    z-index: 200;
  }
  .toast--visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
